schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: CLI wrapper scaffold.
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: go
description: Wrapper scaffold generated by `op new --template`.
kind: wrapper
build:
  runner: go-module
  main: ./cmd/{{.Slug}}
requires:
  commands: [go]
  files: [go.mod]
delegates:
  commands: [echo]
artifacts:
  binary: {{ .Slug }}
