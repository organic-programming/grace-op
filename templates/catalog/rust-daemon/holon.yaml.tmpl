schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: rust
description: Rust daemon scaffold generated by `op new --template`.
kind: native
build:
  runner: cargo
requires:
  commands: [cargo]
  files: [Cargo.toml]
artifacts:
  binary: {{ .Slug }}
