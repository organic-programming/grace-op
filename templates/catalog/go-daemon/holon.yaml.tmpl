schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: go
description: Go daemon scaffold generated by `op new --template`.
kind: native
build:
  runner: go-module
  main: ./cmd/{{.Slug}}
requires:
  commands: [go]
  files: [go.mod]
artifacts:
  binary: {{ .Slug }}
