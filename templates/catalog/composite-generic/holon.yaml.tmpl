schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .DaemonKind }} + {{ .HostUIKind }} composite."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: {{ .Lang }}
description: Composite assembly scaffold.
kind: composite
build:
  runner: recipe
  defaults:
    target: macos
    mode: debug
  members:
    - id: daemon
      path: daemon
      type: component
    - id: app
      path: app
      type: component
  targets:
    macos:
      steps:
        - exec:
            cwd: daemon
            argv: ["sh", "-c", "echo {{ .DaemonKind }} > daemon.txt"]
        - exec:
            cwd: app
            argv: ["sh", "-c", "echo {{ .HostUIKind }} > app.txt"]
        - assert_file:
            path: app/app.txt
requires:
  commands: [sh]
  files: [daemon/README.md, app/README.md]
artifacts:
  primary: app/app.txt
