schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: node
description: Node daemon scaffold generated by `op new --template`.
kind: composite
build:
  runner: npm
requires:
  commands: [node, npm]
  files: [package.json]
artifacts:
  primary: dist/{{ .Slug }}.mjs
