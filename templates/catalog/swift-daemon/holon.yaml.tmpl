schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: swift
description: Swift daemon scaffold generated by `op new --template`.
kind: native
build:
  runner: swift-package
requires:
  commands: [swift]
  files: [Package.swift]
artifacts:
  binary: {{ .Slug }}
