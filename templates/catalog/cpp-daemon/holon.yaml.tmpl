schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: cpp
description: C++ daemon scaffold generated by `op new --template`.
kind: native
build:
  runner: cmake
requires:
  commands: [cmake]
  files: [CMakeLists.txt]
artifacts:
  binary: {{ .Slug }}
