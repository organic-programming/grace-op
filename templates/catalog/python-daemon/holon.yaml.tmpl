schema: holon/v0
uuid: "{{ .UUID }}"
given_name: "{{ .GivenName }}"
family_name: "{{ .FamilyName }}"
motto: "{{ .GivenTitle }} {{ .FamilyTitle }} daemon."
composer: op
clade: deterministic/io_bound
status: draft
born: "{{ .Date }}"
parents: []
reproduction: assisted
generated_by: op
lang: python
description: Python daemon scaffold generated by `op new --template`.
kind: composite
build:
  runner: recipe
  defaults:
    target: linux
    mode: debug
  members:
    - id: app
      path: app
      type: component
  targets:
    linux:
      steps:
        - exec:
            cwd: app
            argv: ["python3", "-m", "py_compile", "main.py"]
        - assert_file:
            path: app/main.py
requires:
  commands: [python3]
  files: [app/main.py]
artifacts:
  primary: app/main.py
